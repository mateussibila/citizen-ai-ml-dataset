      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="_um_BdbdQOneFI8Dn_4h-1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#294265;strokeColor=#5B8DEF;strokeWidth=2;arcSize=1;align=left;spacingLeft=14;spacingTop=8;fontSize=12;fontColor=#E8EEF5;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="10" y="10" width="830" height="1040" as="geometry" />
        </mxCell>
        <mxCell id="ctx" value="Where this sits:  FIELD (Kobo) → COLLECT (CSV + ZIP) → 【 INGEST 】 → STORAGE (Drive) → ANNOTATE → ML" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#152033;strokeColor=#3D8BFF;fontColor=#D7E3F4;fontSize=12;align=center;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="title" value="INGEST — what ingest.py does (Pilot 01)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#E8EEF5;" parent="1" vertex="1">
          <mxGeometry x="40" y="72" width="700" height="32" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Citizen AI / Abundance Federation · volunteer field photos → training-ready dataset" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontColor=#8FA1B8;" parent="1" vertex="1">
          <mxGeometry x="40" y="104" width="700" height="20" as="geometry" />
        </mxCell>
        <mxCell id="input" value="Input&#xa;Kobo CSV + photos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A2A44;strokeColor=#5B8DEF;fontColor=#E8EEF5;fontStyle=1;fontSize=13;arcSize=12;" parent="1" vertex="1">
          <mxGeometry x="40" y="160" width="150" height="56" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="&lt;b&gt;1 · Parse &amp; sanitize&lt;/b&gt;&lt;br&gt;&lt;br&gt;P0-6 · Filename sanitization&lt;br&gt;P0-8 · CSV parsing robustness&lt;br&gt;P0-9 · Text sanitization + capture conditions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#152033;strokeColor=#5B8DEF;strokeWidth=2;arcSize=8;align=left;spacingLeft=14;spacingTop=8;fontSize=12;fontColor=#E8EEF5;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="260" y="140" width="380" height="110" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="&lt;b&gt;2 · Image safety&lt;/b&gt;&lt;br&gt;&lt;br&gt;P0-1 · File size hard cap&lt;br&gt;P0-2 · Image corruption detection&lt;br&gt;P0-3 · Format whitelist (magic numbers)&lt;br&gt;P0-4 · Image bomb / pixel limit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#152033;strokeColor=#5B8DEF;strokeWidth=2;arcSize=8;align=left;spacingLeft=14;spacingTop=8;fontSize=12;fontColor=#E8EEF5;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="260" y="280" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="principle" value="&lt;b&gt;Design rule&lt;/b&gt;&lt;br&gt;If a check fails →&lt;br&gt;quarantine &amp; stop.&lt;br&gt;&lt;br&gt;Bad files never join&lt;br&gt;the active training set.&lt;br&gt;(no &quot;log and keep&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2A2110;strokeColor=#E6A817;fontColor=#F5E6C8;fontSize=11;align=left;spacingLeft=10;spacingTop=8;arcSize=10;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="680" y="280" width="130" height="130" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="&lt;b&gt;3 · Integrity &amp; normalize&lt;/b&gt;&lt;br&gt;&lt;br&gt;P0-5 · EXIF strip + apply orientation → clean JPEG&lt;br&gt;P0-7 · SHA-256 exact duplicate detection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#152033;strokeColor=#5B8DEF;strokeWidth=2;arcSize=8;align=left;spacingLeft=14;spacingTop=8;fontSize=12;fontColor=#E8EEF5;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="260" y="430" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="decision" value="Outcome" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1A2740;strokeColor=#8FA1B8;fontColor=#E8EEF5;fontStyle=1;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="355" y="560" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="accept" value="&lt;b&gt;Accepted&lt;/b&gt;&lt;br&gt;Processed/ images&lt;br&gt;+ master tracking CSV" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#10281C;strokeColor=#3DDC97;fontColor=#3DDC97;fontSize=12;arcSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="80" y="680" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reject" value="&lt;b&gt;Rejected / failed&lt;/b&gt;&lt;br&gt;Quarantine/ folder&lt;br&gt;+ quarantine manifest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2A1414;strokeColor=#FF6B6B;fontColor=#FF8A8A;fontSize=12;arcSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="580" y="680" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="partial" value="partial = some photo slots OK, some quarantined (still audited)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#8FA1B8;fontStyle=2;" parent="1" vertex="1">
          <mxGeometry x="290" y="660" width="340" height="20" as="geometry" />
        </mxCell>
        <mxCell id="audit" value="&lt;b&gt;4 · Structured audit (P0-10)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Every submission gets a disposition row in ingestion_audit.csv:&lt;br&gt;• accepted — all expected images stored&lt;br&gt;• partial — mix of accepted + quarantined slots&lt;br&gt;• rejected — hardening / validation failure&lt;br&gt;• failed — technical / metadata failure (e.g. missing GPS, download)&lt;br&gt;• skipped — already processed on re-import&lt;br&gt;&lt;br&gt;Also logged: run_id, measures triggered, validation summary,&lt;br&gt;output filenames, failure reason + end-of-run summary row." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D1526;strokeColor=#3D8BFF;arcSize=8;align=left;spacingLeft=16;spacingTop=10;fontSize=12;fontColor=#E8EEF5;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="80" y="800" width="700" height="200" as="geometry" />
        </mxCell>
        <mxCell id="sync" value="Next: sync Processed / Reports / Quarantine → Google Drive → annotation (Label Studio)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#8FA1B8;" parent="1" vertex="1">
          <mxGeometry x="80" y="1020" width="700" height="24" as="geometry" />
        </mxCell>
